# =============================================================================
# VoxHorizon web container — runtime + build-time environment variables.
# =============================================================================
# This file documents every env var the Next.js container in web/Dockerfile
# reads. The repo-root .env.example is the source of truth for local dev with
# `pnpm dev`; this file is the source of truth for the production container
# image and is consumed via `env_file: /opt/voxhorizon/.env` in compose.
#
# Copy → /opt/voxhorizon/.env on the VPS, chmod 600, owned by the deploy user.
# Do NOT commit a populated copy of this file. Only this template lives in git.
#
# Two distinct categories of vars live below:
#
#   1. RUNTIME secrets — read by the running container on every request /
#      action. Rotate by editing /opt/voxhorizon/.env and `docker compose
#      restart web`. NO image rebuild required.
#
#   2. BUILD-TIME public values (NEXT_PUBLIC_*) — inlined into the JS bundle
#      by `next build` and shipped to every browser. Rotating any of these
#      requires a CI rebuild + redeploy (the value is baked into the image),
#      NOT just a `docker compose restart`. See web/Dockerfile + the CI
#      workflow added in VPS-10.
# =============================================================================


# -----------------------------------------------------------------------------
# RUNTIME — Supabase
# -----------------------------------------------------------------------------
# Service-role key. Bypasses RLS. SECRET — server-only, never exposed to the
# browser. Used by Server Components and Route Handlers to read/write on
# behalf of the operator.
SUPABASE_SECRET_KEY=


# -----------------------------------------------------------------------------
# RUNTIME — Worker (FastAPI sibling container on the same compose network)
# -----------------------------------------------------------------------------
# In-cluster URL of the worker service. On the VPS this resolves via Docker's
# embedded DNS to the `worker` service: http://worker:8000 (no trailing slash).
# For local dev outside Docker, point this at http://localhost:8000.
WORKER_URL=http://worker:8000

# Shared secret. The web container sends this as `Authorization: Bearer …`
# to every worker call; the worker enforces equality. SECRET.
WORKER_SHARED_SECRET=


# -----------------------------------------------------------------------------
# RUNTIME — Notifications
# -----------------------------------------------------------------------------
# Web Push VAPID private key. Paired with NEXT_PUBLIC_VAPID_PUBLIC_KEY below.
# Generate locally via `npx web-push generate-vapid-keys`. SECRET.
VAPID_PRIVATE_KEY=

# Resend transactional email API key (notifications, alerts). SECRET.
RESEND_API_KEY=


# -----------------------------------------------------------------------------
# RUNTIME — Tailscale-only access gate (defense in depth)
# -----------------------------------------------------------------------------
# Optional. Enforced inside middleware.ts. Off by default.
#   unset / ""  → no gate (Caddy + public DNS are the only access controls)
#   "1"         → log non-tailnet requests, allow them through
#   "strict"    → 403 every non-tailnet request
TAILSCALE_ONLY=

# Optional. Comma-separated CIDRs that count as "tailnet" for the gate above.
# Defaults to 100.64.0.0/10 (the canonical Tailscale CGNAT range) when unset.
TAILSCALE_CIDRS=


# =============================================================================
# BUILD-TIME — NEXT_PUBLIC_* values
# =============================================================================
# These three vars are PUBLIC and inlined into the client bundle at
# `next build` time. The web/Dockerfile receives them via `--build-arg` and
# pipes them through `ENV` so `next build` can substitute them.
#
# ROTATING ANY OF THESE REQUIRES A CI REBUILD + REDEPLOY. A `docker compose
# restart web` will NOT pick up a changed value because the value was baked
# into the static JS bundle the browser already cached. CI sets these from
# GitHub Actions repository secrets in the build workflow (VPS-10).
# =============================================================================

# Supabase project URL (public). Same value as the repo-root .env.example.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon key (public, enforced via RLS).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Web Push VAPID public key. Paired with VAPID_PRIVATE_KEY above.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
