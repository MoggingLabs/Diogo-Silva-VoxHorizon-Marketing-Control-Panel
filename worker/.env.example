# =============================================================================
# worker/.env.example
# -----------------------------------------------------------------------------
# Template for the worker process environment. Copy to `worker/.env` and fill
# in real values (chmod 600). This file is the SINGLE source of truth for the
# names of env vars the worker reads — `worker/scripts/check-env.sh` parses
# every uncommented KEY= line to enforce preflight.
#
# NEVER paste real secret values here. Use placeholder strings like
# `your_dashboard_webhook_token_here`. Real secrets live in the VPS .env or
# 1Password.
#
# Note on provider keys: most legacy provider creds (ElevenLabs, Submagic,
# Meta Ads, GHL, Anthropic) are owned by Ekko inside the Hermes container —
# they live in /docker/hermes-shared/config/secrets.json on the VPS and are
# read by the agent itself, not by this worker. The worker bridges
# dashboard <-> Hermes via docker exec_run; it never sees those keys.
#
# EXCEPTION — KIE_AI_API_KEY: the deterministic image-generation pipeline
# (/work/pipeline/ideation + /work/pipeline/generation and the
# /work/creative/* routes) was restored into this worker because Ekko's
# image-ad-prompting skill is an interactive prompt-writer, not an automated
# dashboard executor. That pipeline calls Kie.ai directly from the worker, so
# the worker DOES need KIE_AI_API_KEY (declared in the External services
# section below).
# =============================================================================

# === Identity ===
# Bearer token shared between the Next.js app (Vercel) and this worker.
# Constant-time compared in auth middleware. Generate with:
#   python -c "import secrets; print(secrets.token_hex(64))"
WORKER_SHARED_SECRET=your_worker_shared_secret_here
# Public URL the Vercel app uses to reach this worker (Tailscale Funnel / VPS
# domain). Used in signed b-roll URLs.
WORKER_PUBLIC_BASE_URL=http://localhost:8000
# CORS origin for the Next.js app (Vercel production URL in prod).
WORKER_CORS_ORIGIN=http://localhost:3000

# === Supabase ===
# Project URL. Stable; obtain from Supabase dashboard → Project Settings → API.
SUPABASE_URL=https://your-project-ref.supabase.co
# Secret key (bypasses RLS). Server-only. Obtain from Supabase dashboard →
# Project Settings → API Keys → "Publishable and Secret API Keys" → Secret.
# New opaque format (sb_secret_*) is recommended; legacy service_role JWT also accepted.
SUPABASE_SECRET_KEY=your_supabase_secret_key_here

# === External services ===
# Kie.ai REST API key. Powers the restored image-generation pipeline: the
# worker submits nano-banana-2 render tasks to https://api.kie.ai for the
# ideation (1:1 previews) and generation (final 1:1 + 9:16) stages, plus the
# /work/creative/generate route. Obtain from the Kie.ai dashboard → API Keys.
# Required at deploy: the pipeline routes raise loudly if it's unset when a
# render is requested. On the VPS this lives in /opt/voxhorizon/.env.
KIE_AI_API_KEY=your_kie_ai_api_key_here

# === Storage ===
# B-roll storage backend: `local` (filesystem under BROLL_LOCAL_ROOT) or
# `supabase` (Supabase Storage signed URLs). Defaults to `local`.
BROLL_STORE_BACKEND=local
# Filesystem root for the local b-roll pool. Tilde-expanded at read time.
BROLL_LOCAL_ROOT=~/voxhorizon-worker/storage/broll-pool

# === Hermes bridge (HI-5, #247) ===
# Name of the co-located Docker container running the Hermes agent (Ekko).
# The worker exec_runs into this container over the host Docker socket to
# forward dashboard chat / kanban commands. Override per environment if
# you run multiple Hermes instances on the same host.
HERMES_CONTAINER_NAME=hermes-agent-ekko
# Bearer token Hermes uses when calling BACK into the worker's webhook
# endpoint (event stream, task updates). Distinct from WORKER_SHARED_SECRET
# so we can rotate either side independently. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
DASHBOARD_WEBHOOK_TOKEN=your_dashboard_webhook_token_here

# === Notifications ===
# VAPID private key for Web Push JWT signing. NEVER rotate unless leaked —
# rotation forces every subscriber to re-subscribe. Generate once with:
#   npx web-push generate-vapid-keys
VAPID_PRIVATE_KEY=your_vapid_private_key_here

# === Slack approval fan-out (HI-17, Slack pivot 2026-05-18) ===
# Slack bot token (xoxb-...) used by worker.approval_notifications.fan_out
# to post a Block Kit message to a single channel when an approval row is
# classified as high-urgency. The bot is `Ekko` (display name) — username
# `apollo`, bot_id B0AKKBG3KMF — in workspace voxhorizon-internal.
#
# Source-of-truth at deploy time: /docker/hermes-shared/config/secrets.json
# on the VPS. Read the `EKKO_SLACK_BOT_TOKEN` field; the deploy step copies
# the value into the worker's runtime env as SLACK_BOT_TOKEN. NEVER paste
# the real value here.
SLACK_BOT_TOKEN=your_slack_bot_token_here
# Static Slack channel ID for #mkt-dept-updates. The bot is already a
# member of this channel. If you change the routing target, update only
# this ID — no code change required.
SLACK_APPROVAL_CHANNEL_ID=C0B43582YJF
# Base URL the Slack "Open in dashboard" CTA links to. The worker never
# serves this URL itself; the link resolves on the operator's browser.
DASHBOARD_BASE_URL=https://dashboard.voxhorizon.com

# === Dormant: Internal Next.js Resend renderer (pre-Slack-pivot) ===
# The previous high-urgency notification path POSTed a payload to
# /api/internal/approval-email on the Next.js side, which rendered a
# react-email template and shipped via Resend. The route + template stay
# in the tree as dormant code (see app/api/internal/approval-email/route.ts
# and lib/emails/HighUrgencyApprovalEmail.tsx) so the pivot is reversible.
# These env vars are no longer read by the worker — listed here for
# inventory only. If the operator decides to revive the email path,
# uncomment and set them, then flip the fan_out branch back.
# INTERNAL_API_BASE_URL=http://web:3000
# INTERNAL_API_TOKEN=your_internal_api_token_here

# === Monitoring ===
# Tailscale MagicDNS hostname for observability / log correlation.
TAILSCALE_HOSTNAME=voxhorizon-worker

# === Reverse proxy (VPS) ===
# Public hostname Caddy will obtain a Let's Encrypt cert for and proxy to the
# worker. Consumed by the `caddy` service in docker-compose.yml, NOT by the
# worker process itself — listed here so the single VPS .env file at
# /opt/voxhorizon/.env carries every var docker compose substitutes.
VOXHORIZON_WORKER_HOST=worker.voxhorizon.example.com
