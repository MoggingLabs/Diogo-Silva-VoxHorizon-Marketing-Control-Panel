# =============================================================================
# worker/.env.example
# -----------------------------------------------------------------------------
# Template for the worker process environment. Copy to `worker/.env` and fill
# in real values (chmod 600). This file is the SINGLE source of truth for the
# names of env vars the worker reads — `worker/scripts/check-env.sh` parses
# every uncommented KEY= line to enforce preflight.
#
# NEVER paste real secret values here. Use placeholder strings like
# `your_dashboard_webhook_token_here`. Real secrets live in the VPS .env or
# 1Password.
#
# Note on legacy provider keys (Kie.ai, ElevenLabs, Submagic, Meta Ads, GHL,
# Anthropic): these are intentionally NOT listed here anymore. Ekko (running
# inside the Hermes container) owns provider credentials now — they live in
# /docker/hermes-shared/config/secrets.json on the VPS and are read by the
# agent itself, not by this worker. The worker only bridges
# dashboard <-> Hermes via docker exec_run; it never sees those keys.
# =============================================================================

# === Identity ===
# Bearer token shared between the Next.js app (Vercel) and this worker.
# Constant-time compared in auth middleware. Generate with:
#   python -c "import secrets; print(secrets.token_hex(64))"
WORKER_SHARED_SECRET=your_worker_shared_secret_here
# Public URL the Vercel app uses to reach this worker (Tailscale Funnel / VPS
# domain). Used in signed b-roll URLs.
WORKER_PUBLIC_BASE_URL=http://localhost:8000
# CORS origin for the Next.js app (Vercel production URL in prod).
WORKER_CORS_ORIGIN=http://localhost:3000

# === Supabase ===
# Project URL. Stable; obtain from Supabase dashboard → Project Settings → API.
SUPABASE_URL=https://your-project-ref.supabase.co
# Secret key (bypasses RLS). Server-only. Obtain from Supabase dashboard →
# Project Settings → API Keys → "Publishable and Secret API Keys" → Secret.
# New opaque format (sb_secret_*) is recommended; legacy service_role JWT also accepted.
SUPABASE_SECRET_KEY=your_supabase_secret_key_here

# === Storage ===
# B-roll storage backend: `local` (filesystem under BROLL_LOCAL_ROOT) or
# `supabase` (Supabase Storage signed URLs). Defaults to `local`.
BROLL_STORE_BACKEND=local
# Filesystem root for the local b-roll pool. Tilde-expanded at read time.
BROLL_LOCAL_ROOT=~/voxhorizon-worker/storage/broll-pool

# === Hermes bridge (HI-5, #247) ===
# Name of the co-located Docker container running the Hermes agent (Ekko).
# The worker exec_runs into this container over the host Docker socket to
# forward dashboard chat / kanban commands. Override per environment if
# you run multiple Hermes instances on the same host.
HERMES_CONTAINER_NAME=hermes-agent-ekko
# Bearer token Hermes uses when calling BACK into the worker's webhook
# endpoint (event stream, task updates). Distinct from WORKER_SHARED_SECRET
# so we can rotate either side independently. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
DASHBOARD_WEBHOOK_TOKEN=your_dashboard_webhook_token_here

# === Notifications ===
# VAPID private key for Web Push JWT signing. NEVER rotate unless leaked —
# rotation forces every subscriber to re-subscribe. Generate once with:
#   npx web-push generate-vapid-keys
VAPID_PRIVATE_KEY=your_vapid_private_key_here

# === Internal Next.js API (HI-17 approval-email fan-out) ===
# Base URL the worker uses to call internal Next.js endpoints. The only
# such endpoint today is /api/internal/approval-email — invoked by the
# worker after inserting a high-urgency approval row to render + send the
# operator email via Resend. In docker-compose this resolves to the web
# service over the internal bridge network (http://web:3000); for local
# dev outside Docker, point at http://localhost:3000.
INTERNAL_API_BASE_URL=http://web:3000
# Shared secret the worker presents as `Authorization: Bearer …` to the
# internal Next.js endpoints above. Must match the Next.js side's
# INTERNAL_API_TOKEN. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_API_TOKEN=your_internal_api_token_here

# === Monitoring ===
# Tailscale MagicDNS hostname for observability / log correlation.
TAILSCALE_HOSTNAME=voxhorizon-worker

# === Reverse proxy (VPS) ===
# Public hostname Caddy will obtain a Let's Encrypt cert for and proxy to the
# worker. Consumed by the `caddy` service in docker-compose.yml, NOT by the
# worker process itself — listed here so the single VPS .env file at
# /opt/voxhorizon/.env carries every var docker compose substitutes.
VOXHORIZON_WORKER_HOST=worker.voxhorizon.example.com
