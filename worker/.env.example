# Worker auth (shared with Vercel side)
WORKER_SHARED_SECRET=

# Public URL the Vercel app uses to reach this worker (Tailscale or LAN)
WORKER_PUBLIC_BASE_URL=http://localhost:8000

# CORS origin for the Next.js app
WORKER_CORS_ORIGIN=http://localhost:3000

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# External services
KIE_AI_API_KEY=
ELEVENLABS_API_KEY=
SUBMAGIC_API_KEY=
META_ADS_API_KEY=

# B-roll storage backend (local | supabase) — defaults to local
BROLL_STORE_BACKEND=local
BROLL_LOCAL_ROOT=~/voxhorizon-worker/storage/broll-pool

# Tailscale (for logging / observability)
TAILSCALE_HOSTNAME=voxhorizon-worker
