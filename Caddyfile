{$VOXHORIZON_DASHBOARD_HOST:dashboard.voxhorizon.example.com} {
	encode zstd gzip

	# Security headers applied to every response, INCLUDING the 401 the
	# basic_auth gate returns. The `defer` keyword wraps the response
	# writer so headers are added even when downstream handlers
	# short-circuit. HSTS is preload-ready (still requires submission to
	# hstspreload.org). CSP allows Next.js hydration (unsafe-inline
	# scripts/styles) and the webpack runtime (unsafe-eval); tighten
	# with nonces via Next.js middleware in a later hardening pass.
	# connect-src hard-codes the Supabase project URL so Realtime (wss)
	# works end-to-end.
	header {
		defer
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=(), interest-cohort=()"
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https://jfzxlsaywztlytnobgej.supabase.co wss://jfzxlsaywztlytnobgej.supabase.co; worker-src 'self' blob:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
		# Drop the `Server: Caddy` fingerprint
		-Server
	}

	# Explicit route ordering ensures the header response handler wraps
	# the basic_auth + reverse_proxy chain so security headers land on
	# the 401 response too (not just the 200 path). Without this, the
	# implicit Caddyfile ordering put `header` before `basic_auth` in
	# the request phase and basic_auth's short-circuit 401 bypassed the
	# response writer wrap.
	route {
		# Single-operator HTTP Basic Auth gate. The bcrypt hash lives in
		# /opt/voxhorizon/.env on the VPS — never in the repo. Caddy
		# reads it as $CADDY_BASIC_AUTH_HASH at startup; an unset value
		# fails Caddy validation (deliberate fail-closed). Future:
		# Cloudflare Access SSO replaces this once we migrate NS to CF.
		basic_auth {
			{$CADDY_BASIC_AUTH_USER:diogo} {$CADDY_BASIC_AUTH_HASH}
		}

		reverse_proxy web:3000 {
			header_up Host {host}
			header_up X-Real-IP {remote_host}

			# SSE: disable Caddy's response buffering so chat-stream tokens
			# arrive at the client in real time, not at the end of the agent
			# turn. -1 means "flush after every write" — required for the
			# chat-with-Ekko SSE endpoint to feel interactive.
			flush_interval -1
		}
	}

	log {
		output file /var/log/caddy/access.log {
			roll_size 50mb
			roll_keep 5
		}
		format json
	}
}
