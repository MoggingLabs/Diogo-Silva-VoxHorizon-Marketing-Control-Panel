{$VOXHORIZON_DASHBOARD_HOST:dashboard.voxhorizon.example.com} {
	encode zstd gzip

	# Security headers, applied to every response (including the 401 the
	# basic_auth gate returns). HSTS is preload-ready but you still have
	# to submit to hstspreload.org for the browser preload list. CSP
	# allows Next.js hydration (unsafe-inline scripts/styles) and the
	# webpack runtime (unsafe-eval); tighten with nonces via Next.js
	# middleware in a later hardening pass. connect-src has the Supabase
	# project URL hard-wired so Realtime (wss) works end-to-end.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=(), interest-cohort=()"
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https://jfzxlsaywztlytnobgej.supabase.co wss://jfzxlsaywztlytnobgej.supabase.co; worker-src 'self' blob:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
		# Drop the `Server: Caddy` fingerprint
		-Server
	}

	# Single-operator HTTP Basic Auth gate at the edge.
	#
	# v1 is one user (Diogo). The bcrypt hash lives in
	# /opt/voxhorizon/.env on the VPS — never in the repo. Caddy reads
	# it as $CADDY_BASIC_AUTH_HASH at startup; substituting an unset
	# value fails Caddy validation (deliberate fail-closed). Browsers
	# cache the Authorization header for the session, so assets, /api
	# routes, and SSE streams all carry the credential without extra
	# round trips.
	#
	# Future: replace with Cloudflare Access (NS migration to CF +
	# email-PIN or Google SSO) when we want SSO + audit logs.
	basic_auth {
		{$CADDY_BASIC_AUTH_USER:diogo} {$CADDY_BASIC_AUTH_HASH}
	}

	reverse_proxy web:3000 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}

		# SSE: disable Caddy's response buffering so chat-stream tokens
		# arrive at the client in real time, not at the end of the agent
		# turn. -1 means "flush after every write" — required for the
		# chat-with-Ekko SSE endpoint to feel interactive.
		flush_interval -1
	}

	log {
		output file /var/log/caddy/access.log {
			roll_size 50mb
			roll_keep 5
		}
		format json
	}
}
