# =============================================================================
# VoxHorizon Marketing Control Panel — environment variables
# =============================================================================
# Copy this file to .env.local for local development.
# Do NOT commit .env or .env.local — only this template lives in git.
# All variables are trimmed of trailing whitespace via lib/env.ts (cleanEnv).
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
# Project URL (public). Available in: Supabase Dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=

# Anon key (public). Safe to ship to the browser. Enforce auth via RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key (SECRET, server-only). Bypasses RLS — never expose to client.
SUPABASE_SECRET_KEY=

# -----------------------------------------------------------------------------
# Worker (Python FastAPI service running on Tailscale-only host)
# -----------------------------------------------------------------------------
# Internal worker URL, e.g. http://worker.tailnet:8080 (no trailing slash).
WORKER_URL=

# Shared secret used as Bearer token between Next.js and the worker.
WORKER_SHARED_SECRET=

# Narrowly-scoped bearer token for the /work/hermes/approval* routes.
# The voxhorizon-approvals Hermes plugin AND the Next.js dashboard both
# use this when calling the worker's approval / approval-mode endpoints.
# Separate from WORKER_SHARED_SECRET so a compromise in either client
# scope can't pivot to the other.
VOXHORIZON_APPROVAL_TOKEN=

# -----------------------------------------------------------------------------
# App-layer session auth (single-operator login gate, defense-in-depth)
# -----------------------------------------------------------------------------
# Secret used to HMAC-sign the single-operator session cookie. The login route
# issues a signed HttpOnly+SameSite cookie; middleware.ts verifies it on every
# non-public request. REQUIRED for login to work (a blank value makes the login
# route return 503 and the gate treat every request as unauthenticated).
#
# Generate a strong value (do NOT reuse another secret):
#   openssl rand -base64 48
#   # or: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=
#
# Seed the SINGLE operator row (migration 0057 `operators` table). The login
# route verifies the presented password against this row's bcrypt hash. Store
# the email lowercased; generate the bcrypt hash with bcryptjs (cost 10):
#   node -e "console.log(require('bcryptjs').hashSync(process.argv[1], 10))" 'your-password'
# then insert (service-role, RLS deny-all blocks anon):
#   insert into operators (email, password_hash)
#   values ('operator@yourdomain.com', '$2a$10$...the-hash...')
#   on conflict (email) do update set password_hash = excluded.password_hash;

# -----------------------------------------------------------------------------
# Tailscale-only access gate (LEGACY — superseded by the session gate above)
# -----------------------------------------------------------------------------
# The middleware no longer reads these; the Tailscale IP gate was replaced by
# the single-operator session gate. Kept here for inventory / future revival.
# TAILSCALE_ONLY=
# TAILSCALE_CIDRS=

# -----------------------------------------------------------------------------
# Notifications
# -----------------------------------------------------------------------------
# Web Push (VAPID) keys. Generate via `npx web-push generate-vapid-keys`.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- Slack high-urgency approval fan-out (HI-17, Slack pivot 2026-05-18) ---
# Bot token for the `Ekko` bot in workspace voxhorizon-internal. The worker
# uses chat.postMessage to surface high-urgency approval rows. Source the
# real value from /docker/hermes-shared/config/secrets.json on the VPS
# (key: EKKO_SLACK_BOT_TOKEN) — never paste it into git history.
SLACK_BOT_TOKEN=

# Static Slack channel ID for the destination channel (e.g. #mkt-dept-updates).
SLACK_APPROVAL_CHANNEL_ID=

# Base URL embedded in the "Open in dashboard" CTA the bot posts. Mirrored
# from the worker config so both surfaces line up.
DASHBOARD_BASE_URL=https://dashboard.voxhorizon.com

# --- Dormant (pre-Slack-pivot) ---
# These were used by the Resend transactional-email path that has been
# disabled in favor of Slack. The Next.js route + react-email template
# remain in the tree as dormant code; if the operator reverses the pivot
# they need to be set again. Listed for inventory only.
# RESEND_API_KEY=
# OPERATOR_EMAIL=
# INTERNAL_API_TOKEN=
